generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// User model for authentication and RBAC
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String   // hashed password
  role      UserRole @default(user)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations (to be used by auth-and-data-model workstream)
  sessions    ChatSession[]
  preferences UserPreference?
  bookmarks   CodeBookmark[]

  @@map("users")
}

model CodeBookmark {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  sessionId   String   @map("session_id")
  messageId   String   @map("message_id")
  title       String
  codePreview String   @map("code_preview") @db.Text
  codeContent String   @map("code_content") @db.LongText
  language    String
  lineNumber  Int?     @map("line_number")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([messageId])
  @@map("code_bookmarks")
}

enum UserRole {
  admin
  user
}

// System configuration for LLM provider settings
// Singleton pattern: only one record should exist
model SystemConfig {
  id            String   @id @default(cuid())
  openaiApiKey  String?  @map("openai_api_key") @db.Text
  openaiBaseUrl String?  @map("openai_base_url")
  // Allowed models stored as JSON array
  allowedModels Json     @default("[]") @map("allowed_models")
  // MCP servers configuration stored as JSON
  mcpServers    Json     @default("{\"version\":1,\"servers\":[]}") @map("mcp_servers")
  // Exa search configuration stored as JSON
  searchConfig  Json     @default("{\"version\":1}") @map("search_config")
  updatedAt     DateTime @updatedAt @map("updated_at")
  updatedBy     String?  @map("updated_by")

  @@map("system_config")
}

// Chat sessions for organizing conversations
model ChatSession {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")
  userId    String   @map("user_id")
  model     String   // The model used for this chat
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

// Individual chat messages
model ChatMessage {
  id                String       @id @default(cuid())
  sessionId         String       @map("session_id")
  role              MessageRole
  model             String?
  content           String       @db.LongText
  // Reasoning/thinking content from models that support it
  reasoning         String?      @db.LongText @map("reasoning")
  // Follow-up question suggestions stored as JSON array
  followUpQuestions Json?        @map("follow_up_questions")
  createdAt         DateTime     @default(now()) @map("created_at")

  // Relations
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

enum MessageRole {
  user
  assistant
  system
}

// User preferences for chat settings
model UserPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  chatNetworkEnabled Boolean  @default(true) @map("chat_network_enabled")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
