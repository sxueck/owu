# Database Configuration
DATABASE_URL="mysql://owu:owupassword@localhost:3306/owu"
SHADOW_DATABASE_URL="mysql://owu:owupassword@localhost:3306/owu_shadow"

# MySQL Docker Configuration (for docker-compose)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=owu
MYSQL_USER=owu
MYSQL_PASSWORD=owupassword
MYSQL_PORT=3306

# Session Configuration
SESSION_SECRET="your-secret-key-change-this-in-production"

# OpenAI Configuration (Server-only, never exposed to browser)
# These will be configured via admin panel and stored in database
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# Application Configuration
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
APP_VERSION=0.1.0
